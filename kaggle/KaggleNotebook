    "import json\n",
    "from pathlib import Path\n",
    "from collections import defaultdict\n",
    "import sys\n",
    "\n",
    "def calculate_stats(file_path: str):\n",
    "    \"\"\"\n",
    "    Reads an experiment results JSON file and prints or returns statistics.\n",
    "    \"\"\"\n",
    "    path = Path(file_path)\n",
    "    if not path.exists():\n",
    "        print(f\"Error: File '{file_path}' not found.\")\n",
    "        return\n",
    "\n",
    "    with open(path, 'r', encoding='utf-8') as f:\n",
    "        try:\n",
    "            results = json.load(f)\n",
    "        except json.JSONDecodeError as e:\n",
    "            print(f\"Error decoding JSON: {e}\")\n",
    "            return\n",
    "\n",
    "    total_problems = len(results)\n",
    "    completed_count = 0\n",
    "    failed_count = 0\n",
    "    total_turns = 0\n",
    "    \n",
    "    # Track error distribution or specific status occurrences\n",
    "    statuses = defaultdict(int)\n",
    "    \n",
    "    for item in results:\n",
    "        status = item.get(\"status\", \"unknown\")\n",
    "        statuses[status] += 1\n",
    "        \n",
    "        if status == \"completed\":\n",
    "            completed_count += 1\n",
    "        elif status == \"failed\":\n",
    "            failed_count += 1\n",
    "            \n",
    "        total_turns += item.get(\"num_turns\", 0)\n",
    "        \n",
    "    # Compute metrics safely\n",
    "    avg_turns = total_turns / total_problems if total_problems > 0 else 0\n",
    "    completion_rate = (completed_count / total_problems) * 100 if total_problems > 0 else 0\n",
    "\n",
    "    stats = {\n",
    "        \"Total Problems Evaluated\": total_problems,\n",
    "        \"Completed\": completed_count,\n",
    "        \"Failed\": failed_count,\n",
    "        \"Success Rate\": f\"{completion_rate:.2f}%\",\n",
    "        \"Total Turns Across Problems\": total_turns,\n",
    "        \"Average Turns Per Problem\": round(avg_turns, 2),\n",
    "        \"Breakdown by Status\": dict(statuses)\n",
    "    }\n",
    "\n",
    "    # Pretty print the output\n",
    "    print(\"=\" * 40)\n",
    "    print(\" EXPERIMENT STATISTICS SUMMARY\")\n",
    "    print(\"=\" * 40)\n",
    "    for key, value in stats.items():\n",
    "        if isinstance(value, dict):\n",
    "            print(f\"{key}:\")\n",
    "            for k, v in value.items():\n",
    "                print(f\"  - {k}: {v}\")\n",
    "        else:\n",
    "            print(f\"{key}: {value}\")\n",
    "    print(\"=\" * 40)\n",
    "\n",
    "    return stats"
   ]
  },
