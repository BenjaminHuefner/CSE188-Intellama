    "from pathlib import Path\n",
    "import os\n",
    "import shutil\n",
    "import sys\n",
    "from kaggle_secrets import UserSecretsClient\n",
    "\n",
    "user_secrets = UserSecretsClient()\n",
    "repo_path = user_secrets.get_secret(\"REPO_PATH\")\n",
    "source_repo = Path(repo_path)\n",
    "target_dir = Path('/kaggle/working/intellama')\n",
    "\n",
    "if source_repo.exists():\n",
    "    shutil.copytree(source_repo, target_dir, dirs_exist_ok=True)\n",
    "    print(f'Copied repo to {target_dir}')\n",
    "else:\n",
    "    print(f'Repo dataset not found at {source_repo}; make sure the GitHub repo is attached as a Kaggle dataset.')\n",
    "\n",
    "os.chdir(target_dir)\n",
    "print(f'Working directory: {Path.cwd()}')"
   ]
